# Immich version — pin to a specific release (e.g. v2.6.3) or use 'release'
IMMICH_VERSION=release

# NAS (CIFS) — photos share
NAS_HOST=192.168.1.100
NAS_PHOTOS_SHARE=photos
NAS_PHOTOS_USER=immich
NAS_PHOTOS_PASS=CHANGE_ME

# Database — use only alphanumeric characters for the password (A-Za-z0-9)
DB_DATA_LOCATION=./appdata/postgres
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_TO_A_RANDOM_STRING
DB_DATABASE_NAME=immich

# Hardware acceleration backends (change to match your GPU)
# Transcoding options: nvenc (NVIDIA), quicksync (Intel), vaapi, cpu
IMMICH_TRANSCODING_BACKEND=nvenc
# ML options: cuda (NVIDIA), openvino (Intel), armnn, cpu
# ML image suffix must match backend: -cuda, -rocm, -openvino, -armnn, -rknn (or blank for cpu)
IMMICH_ML_BACKEND=cuda
IMMICH_ML_IMAGE_SUFFIX=-cuda

# Tailscale
TS_AUTHKEY=tskey-auth-xxxxx
