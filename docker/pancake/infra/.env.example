# Tailscale
TS_AUTHKEY=tskey-auth-xxxxx

# Homepage dashboard — your tailnet name (the part before .ts.net)
TAILNET=your-tailnet-name

# Homepage API keys (grab from each app's UI after first boot)
SONARR_API_KEY=
RADARR_API_KEY=
PROWLARR_API_KEY=
PLEX_TOKEN=
IMMICH_API_KEY=
PORTAINER_API_KEY=

# AdGuard (charm's replica instance)
ADGUARD_USER=admin
ADGUARD_PASS=
