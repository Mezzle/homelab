# Seedbox (SSHFS via rclone)
SEEDBOX_HOST=your-seedbox.example.com
SEEDBOX_USER=your-username
SEEDBOX_PORT=22
SEEDBOX_REMOTE_PATH=/home/your-username/downloads

# NAS (SMB/CIFS)
NAS_HOST=192.168.1.100
NAS_SHARE=media
NAS_BACKUP_SHARE=backup
NAS_USER=your-nas-user
NAS_PASS=your-nas-password

# PIA VPN
PIA_USER=your-pia-username
PIA_PASS=your-pia-password
PIA_REGION=Netherlands

# Plex (get a fresh token at https://plex.tv/claim — expires in 4 minutes)
PLEX_CLAIM=

# arr API keys (grab from each app's Settings > General after first boot)
# Needed by Recyclarr and Bazarr
SONARR_API_KEY=
RADARR_API_KEY=

# Discord webhook for backup notifications (optional — leave blank to disable)
DISCORD_WEBHOOK_URL=

# Tailscale (generate at https://login.tailscale.com/admin/settings/keys)
# Recommended: reusable + ephemeral, tagged with a relevant ACL tag
TS_AUTHKEY=tskey-auth-xxxxx
